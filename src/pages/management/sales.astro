---
import ManagementLayout from "../../layouts/ManagementLayout.astro";
import SalesListView from "../../components/management/SalesListView";
import ConfirmationModal from "../../components/common/ConfirmationModal.astro";
import modalStyles from "../../components/common/styles/ConfirmationModal.module.css";

const title = "Gestión de Ventas";
---

<ManagementLayout title={title}>
    <SalesListView client:visible />

    <ConfirmationModal
        id="complete-sale-modal"
        title="Completar Registro de Venta"
        message="¿Estás seguro de que deseas completar este registro de venta? El estado pasará a COMPLETADO y se reflejará en las estadísticas de ingresos."
        confirmText="Completar Venta"
        cancelText="Volver"
        type="default"
    />

    <ConfirmationModal
        id="cancel-sale-modal"
        title="Cancelar Registro de Venta"
        message="¿Estás seguro de que deseas cancelar este registro de venta? El estado pasará a CANCELADO."
        confirmText="Confirmar Cancelación"
        cancelText="Volver"
        type="danger"
    />

    <ConfirmationModal
        id="delete-sale-modal"
        title="Borrar Registro de Venta"
        message="¿Estás seguro de que deseas borrar este registro de venta? Pasará a estado BORRADO y se ocultará del listado principal."
        confirmText="Borrar"
        cancelText="Cancelar"
        type="danger"
    />
</ManagementLayout>

<script is:inline define:vars={{ modalStyles }}>
    const setupModal = (modalId, globalName) => {
        window[globalName] = (onConfirm) => {
            const modal = document.getElementById(modalId);
            const confirmBtn = document.getElementById(`${modalId}-confirm`);
            const cancelBtn = document.getElementById(`${modalId}-cancel`);

            if (!modal || !confirmBtn || !cancelBtn) return;

            modal.classList.add(modalStyles.active);

            const handleConfirm = () => {
                onConfirm();
                modal.classList.remove(modalStyles.active);
                cleanup();
            };

            const handleCancel = () => {
                modal.classList.remove(modalStyles.active);
                cleanup();
            };

            const cleanup = () => {
                confirmBtn.removeEventListener("click", handleConfirm);
                cancelBtn.removeEventListener("click", handleCancel);
            };

            confirmBtn.addEventListener("click", handleConfirm);
            cancelBtn.addEventListener("click", handleCancel);
        };
    };

    setupModal("delete-sale-modal", "showDeleteSaleModal");
    setupModal("complete-sale-modal", "showCompleteSaleModal");
    setupModal("cancel-sale-modal", "showCancelSaleModal");
</script>

