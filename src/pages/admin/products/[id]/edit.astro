---
import AdminLayout from "../../../../layouts/AdminLayout.astro";
import EditProductView from "../../../../components/admin/EditProductView";

const { id } = Astro.params;

if (!id) {
    return Astro.redirect("/admin/products");
}
---

<AdminLayout
    title="Editar Producto"
    parentTitle="Gestión de Productos"
    parentUrl="/admin/products"
>
    <EditProductView productId={id} client:load />
</AdminLayout>
