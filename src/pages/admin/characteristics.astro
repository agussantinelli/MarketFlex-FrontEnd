---
import AdminLayout from "../../layouts/AdminLayout.astro";
import CharacteristicsListView from "../../components/admin/CharacteristicsListView";
import ConfirmationModal from "../../components/common/ConfirmationModal.astro";
import modalStyles from "../../components/common/styles/ConfirmationModal.module.css";
---

<AdminLayout
    title="Gestión de Características"
    parentTitle="Administración"
    parentUrl="/admin/dashboard"
>
    <CharacteristicsListView client:only="react" />

    <ConfirmationModal
        id="delete-characteristic-modal"
        title="Borrar Característica"
        message="¿Estás seguro de que deseas borrar esta característica? Solo se podrá borrar si no tiene productos asociados."
        confirmText="Borrar"
        cancelText="Cancelar"
        type="danger"
    />
</AdminLayout>

<script is:inline define:vars={{ modalStyles }}>
    window.showDeleteCharacteristicModal = (onConfirm) => {
        const modal = document.getElementById("delete-characteristic-modal");
        const confirmBtn = document.getElementById(
            "delete-characteristic-modal-confirm",
        );
        const cancelBtn = document.getElementById(
            "delete-characteristic-modal-cancel",
        );

        if (!modal || !confirmBtn || !cancelBtn) return;

        modal.classList.add(modalStyles.active);

        const handleConfirm = () => {
            onConfirm();
            modal.classList.remove(modalStyles.active);
            cleanup();
        };

        const handleCancel = () => {
            modal.classList.remove(modalStyles.active);
            cleanup();
        };

        const cleanup = () => {
            confirmBtn.removeEventListener("click", handleConfirm);
            cancelBtn.removeEventListener("click", handleCancel);
        };

        confirmBtn.addEventListener("click", handleConfirm);
        cancelBtn.addEventListener("click", handleCancel);
    };
</script>
