---
import { Icon } from "astro-icon/components";
import UserDropdown from "../shared/UserDropdown.astro";
import styles from "./styles/ManagementHeader.module.css";

interface Props {
    title: string;
    parentTitle?: string | undefined;
    parentUrl?: string | undefined;
}

const { title, parentTitle, parentUrl } = Astro.props;
---

<header class={styles.ManagementHeader}>
    <div class={styles.headerLeft}>
        <button
            id="sidebar-toggle"
            class={styles.mobileMenuBtn}
            aria-label="Abrir menú"
        >
            <Icon name="lucide:menu" class={styles.menuIcon} />
        </button>
        <div class={styles.breadcrumb}>
            <a href="/management/dashboard" class={styles.breadcrumbText}
                >Gestión</a
            >
            <Icon name="lucide:chevron-right" class={styles.breadcrumbIcon} />
            {
                parentTitle && (
                    <>
                        <a
                            href={parentUrl || "#"}
                            class={styles.breadcrumbText}
                        >
                            {parentTitle}
                        </a>
                        <Icon
                            name="lucide:chevron-right"
                            class={styles.breadcrumbIcon}
                        />
                    </>
                )
            }
            <span class={styles.breadcrumbTitle}>{title}</span>
        </div>
    </div>

    <div class={styles.headerRight}>
        <UserDropdown />
    </div>
</header>

<script>
    const btn = document.getElementById("sidebar-toggle");
    if (btn) {
        btn.addEventListener("click", () => {
            window.dispatchEvent(new CustomEvent("toggle-management-sidebar"));
        });
    }
</script>

