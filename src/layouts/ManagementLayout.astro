---
import "../styles/globals.css";
import ManagementSidebar from "../components/management/ManagementSidebar";
import ManagementHeader from "../components/management/ManagementHeader.astro";
import LoadingSpinner from "../components/common/LoadingSpinner";
import Notifications from "../components/common/Notifications";
import { ViewTransitions } from "astro:transitions";
import "sileo/styles.css";

interface Props {
    title: string;
    parentTitle?: string | undefined;
    parentUrl?: string | undefined;
}

const { title, parentTitle, parentUrl } = Astro.props;
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="description" content="Panel de Control MarketFlex" />
        <link
            rel="icon"
            type="image/svg+xml"
            href="/logo-marketflex-circle.png"
        />
        <meta name="generator" content={Astro.generator} />
        <title>{title} | MarketFlex</title>
        <ViewTransitions />
        <script is:inline>
            window.showManagementLoader = () => {
                const overlay = document.getElementById("nav-loading-overlay");
                if (overlay) overlay.classList.add("active");
            };

            window.hideManagementLoader = () => {
                const overlay = document.getElementById("nav-loading-overlay");
                if (overlay) overlay.classList.remove("active");
            };

            // Aliases for compatibility
            window.showSellerLoader = window.showManagementLoader;
            window.hideSellerLoader = window.hideManagementLoader;

            // Start loader on transition
            document.addEventListener("astro:before-preparation", () => {
                window.showManagementLoader();
            });

            // Fallback: hide loader after 15 seconds if no component signals
            document.addEventListener("astro:page-load", () => {
                setTimeout(() => {
                    const overlay = document.getElementById(
                        "nav-loading-overlay",
                    );
                    if (overlay && overlay.classList.contains("active")) {
                        window.hideManagementLoader();
                    }
                }, 15000);
            });
        </script>
        <style>
            .management-container {
                display: flex;
                min-height: 100vh;
                background-color: var(--background);
                position: relative;
            }
            .management-main {
                flex: 1;
                margin-left: 260px;
                display: flex;
                flex-direction: column;
                min-width: 0;
                transition: margin-left 0.3s ease;
            }
            .management-content {
                flex: 1;
                padding: 2rem;
                overflow-y: auto;
                overflow-x: hidden;
                min-width: 0;
            }

            @media (max-width: 1024px) {
                .management-main {
                    margin-left: 0;
                }
                .management-content {
                    padding: 1.5rem;
                }
            }

            .nav-loading-overlay {
                display: none;
                position: fixed;
                top: 0;
                left: 0;
                width: 100vw;
                height: 100vh;
                background: rgba(15, 23, 42, 0.8);
                backdrop-filter: blur(8px);
                z-index: 9999;
                align-items: center;
                justify-content: center;
            }

            .nav-loading-overlay.active {
                display: flex;
            }
        </style>
    </head>
    <body>
        <div class="management-container">
            <div id="nav-loading-overlay" class="nav-loading-overlay">
                <LoadingSpinner fullPage message="Cargando..." />
            </div>
            <ManagementSidebar client:load />
            <div class="management-main">
                <ManagementHeader
                    title={title}
                    parentTitle={parentTitle}
                    parentUrl={parentUrl}
                />
                <main class="management-content">
                    <slot />
                </main>
            </div>
        </div>

        <span id="sileo-root"></span>

        <script>
            const checkAccess = () => {
                const userStr = localStorage.getItem("marketflex_user");
                const path = window.location.pathname;

                if (!userStr) {
                    window.location.href = `/login?redirect=${path}`;
                    return;
                }

                try {
                    const user = JSON.parse(userStr);

                    // Allow both admin and seller for management/seller routes
                    if (user.rol !== "admin" && user.rol !== "seller") {
                        window.location.href = "/";
                        return;
                    }

                    // Admin only routes protection
                    const adminOnlyPaths = [
                        "/management/users",
                        "/management/analytics",
                    ];
                    if (
                        user.rol === "seller" &&
                        adminOnlyPaths.some((p) => path.startsWith(p))
                    ) {
                        window.location.href = "/management/dashboard";
                        return;
                    }
                } catch (e) {
                    window.location.href = "/login";
                }
            };

            checkAccess();
            document.addEventListener("astro:after-swap", checkAccess);
        </script>
        <Notifications client:only="react" />
    </body>
</html>
